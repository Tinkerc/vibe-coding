<mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1000" math="0" shadow="0">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="用户注册流程 User Registration Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="400" y="20" width="400" height="30" as="geometry"/>
    </mxCell>

    <!-- Start -->
    <mxCell id="start" value="开始&#xa;Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="520" y="80" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- Input -->
    <mxCell id="input" value="用户输入注册信息&#xa;• 用户名&#xa;• 邮箱&#xa;• 密码" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="500" y="180" width="200" height="80" as="geometry"/>
    </mxCell>

    <!-- Validate Format -->
    <mxCell id="validate" value="验证输入格式&#xa;Validate Input Format" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
      <mxGeometry x="500" y="300" width="200" height="60" as="geometry"/>
    </mxCell>

    <!-- Decision: Format Valid? -->
    <mxCell id="dec_format" value="格式有效?&#xa;Valid?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="520" y="400" width="160" height="100" as="geometry"/>
    </mxCell>

    <!-- Error: Invalid Format -->
    <mxCell id="error_format" value="返回错误：&#xa;格式无效&#xa;Invalid Format" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="800" y="420" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- Check Exists -->
    <mxCell id="check_exists" value="检查用户名/邮箱&#xa;是否已存在&#xa;Check if Exists" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="500" y="540" width="200" height="60" as="geometry"/>
    </mxCell>

    <!-- Decision: Exists? -->
    <mxCell id="dec_exists" value="已存在?&#xa;Exists?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="520" y="640" width="160" height="100" as="geometry"/>
    </mxCell>

    <!-- Error: Already Exists -->
    <mxCell id="error_exists" value="返回错误：&#xa;用户已存在&#xa;User Exists" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="800" y="660" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- Hash Password -->
    <mxCell id="hash" value="密码加密&#xa;Hash Password&#xa;(bcrypt/argon2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="500" y="780" width="200" height="70" as="geometry"/>
    </mxCell>

    <!-- Save to DB -->
    <mxCell id="save_db" value="保存到数据库&#xa;Save to Database" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="520" y="890" width="160" height="80" as="geometry"/>
    </mxCell>

    <!-- Send Email -->
    <mxCell id="send_email" value="发送验证邮件&#xa;Send Verification Email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1" vertex="1" parent="1">
      <mxGeometry x="260" y="905" width="160" height="50" as="geometry"/>
    </mxCell>

    <!-- Success -->
    <mxCell id="success" value="注册成功&#xa;Registration Success&#xa;返回用户信息" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="500" y="1010" width="200" height="60" as="geometry"/>
    </mxCell>

    <!-- End -->
    <mxCell id="end" value="结束&#xa;End" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="520" y="1110" width="160" height="60" as="geometry"/>
    </mxCell>

    <!-- ==================== EDGES ==================== -->

    <!-- Start -> Input -->
    <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" source="start" target="input" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Input -> Validate -->
    <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" source="input" target="validate" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Validate -> Dec Format -->
    <mxCell id="e3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" source="validate" target="dec_format" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Dec Format -> Error Format (No) -->
    <mxCell id="e4" value="否 No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;" edge="1" source="dec_format" target="error_format" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Error Format -> End -->
    <mxCell id="e5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;dashed=1;" edge="1" source="error_format" target="end" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="880" y="1140"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Dec Format -> Check Exists (Yes) -->
    <mxCell id="e6" value="是 Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82b366;" edge="1" source="dec_format" target="check_exists" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Check Exists -> Dec Exists -->
    <mxCell id="e7" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" source="check_exists" target="dec_exists" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Dec Exists -> Error Exists (Yes) -->
    <mxCell id="e8" value="是 Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;" edge="1" source="dec_exists" target="error_exists" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Error Exists -> End -->
    <mxCell id="e9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#b85450;dashed=1;" edge="1" source="error_exists" target="end" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="880" y="1140"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Dec Exists -> Hash (No) -->
    <mxCell id="e10" value="否 No" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82b366;" edge="1" source="dec_exists" target="hash" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Hash -> Save DB -->
    <mxCell id="e11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" source="hash" target="save_db" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Save DB -> Send Email (Optional) -->
    <mxCell id="e12" value="可选 Optional" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82b366;dashed=1;" edge="1" source="save_db" target="send_email" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Send Email -> Success -->
    <mxCell id="e13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#82b366;dashed=1;" edge="1" source="send_email" target="success" parent="1">
      <mxGeometry relative="1" as="geometry">
        <Array as="points">
          <mxPoint x="340" y="1040"/>
        </Array>
      </mxGeometry>
    </mxCell>

    <!-- Save DB -> Success (Direct) -->
    <mxCell id="e14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" source="save_db" target="success" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Success -> End -->
    <mxCell id="e15" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#666666;" edge="1" source="success" target="end" parent="1">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Legend -->
    <mxCell id="legend" value="图例 Legend" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1" vertex="1" parent="1">
      <mxGeometry x="50" y="80" width="100" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="legend_start" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="50" y="110" width="40" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="legend_start_text" value="开始/结束" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="100" y="110" width="80" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="legend_process" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="50" y="140" width="40" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="legend_process_text" value="处理步骤" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="100" y="140" width="80" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="legend_decision" value="" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="50" y="170" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="legend_decision_text" value="判断决策" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="100" y="175" width="80" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="legend_error" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="50" y="210" width="40" height="25" as="geometry"/>
    </mxCell>
    <mxCell id="legend_error_text" value="错误处理" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="100" y="210" width="80" height="25" as="geometry"/>
    </mxCell>

    <mxCell id="legend_db" value="" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="45" y="245" width="50" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="legend_db_text" value="数据库操作" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="100" y="245" width="80" height="25" as="geometry"/>
    </mxCell>

  </root>
</mxGraphModel>
